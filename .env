# ============================================
# DEEPSEEK API CONFIGURATION
# ============================================
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN=http://localhost:3000,https://socolovai.onrender.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# AI CONFIGURATION - КАК У DEEPSEEK
# ============================================
DEFAULT_MODEL=deepseek-chat
MAX_TOKENS=16384
TEMPERATURE=1.0
SYSTEM_PROMPT=Ты — Соколов AI, интеллектуальный помощник на базе DeepSeek. Отвечай на русском языке, будь полезным, дружелюбным и профессиональным. Будь креативным, но оставайся точным. Помогай с программированием, анализом кода и ответами на вопросы.

# ============================================
# КОНФИГУРАЦИЯ АНАЛИЗА КОДА (как у меня)
# ============================================
CODE_ANALYSIS_MAX_TOKENS=16384
CODE_ANALYSIS_TEMPERATURE=0.3

# ============================================
# НАСТРОЙКИ ПАМЯТИ - КАК У МЕНЯ (1M токенов)
# ============================================
MAX_HISTORY_MESSAGES=100
MAX_CODE_LENGTH=200000
CONTEXT_WINDOW=1000000

# ============================================
# ТАЙМАУТЫ
# ============================================
REQUEST_TIMEOUT_MS=300000
FILE_UPLOAD_TIMEOUT_MS=600000
