DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
PORT=3000
NODE_ENV=production

CORS_ORIGIN=http://localhost:3000,https://socolovai.onrender.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
DEFAULT_MODEL=deepseek-chat
MAX_TOKENS=16384
TEMPERATURE=0.8
SYSTEM_PROMPT=Ты — Соколов AI, интеллектуальный помощник на базе DeepSeek. Отвечай на русском языке, будь полезным, дружелюбным и профессиональным. Помогай с программированием, анализом кода и ответами на вопросы.
CODE_ANALYSIS_MAX_TOKENS=16384
CODE_ANALYSIS_TEMPERATURE=0.3
MAX_HISTORY_MESSAGES=20
MAX_CODE_LENGTH=200000
REQUEST_TIMEOUT_MS=600000
FILE_UPLOAD_TIMEOUT_MS=600000
